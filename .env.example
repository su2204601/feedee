# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (production only)
POSTGRES_DB=feedee
POSTGRES_USER=feedee
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Nginx (production only)
NGINX_PORT=80

# CSRF trusted origins (production only, comma-separated)
CSRF_TRUSTED_ORIGINS=https://your-domain.example.com

# RSS Worker
# DJANGO_BASE_URL is set in compose files; override here if needed
# HTTP_TIMEOUT_SECONDS=15
# MAX_CONCURRENCY=8
# INGEST_MAX_RETRY=3
# INGEST_INITIAL_BACKOFF_SECONDS=1
